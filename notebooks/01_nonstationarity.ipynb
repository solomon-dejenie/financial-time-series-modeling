## Purpose
### To Detect:

#### 1 unit roots
#### 2 stochastic trends
#### 3 equilibrium relationships

import pandas as pd
import numpy as np
import statsmodels.api as sm
from statsmodels.tsa.stattools import adfuller
from statsmodels.tsa.vector_ar.vecm import coint_johansen

# Load data

data = pd.read_csv('data/raw/macro_data.csv')

# Unit root test
result = adfuller(data['GDP'])
print('ADF Statistic:', result[0])
print('p-value:', result[1])

# Cointegration test
jres = coint_johansen(
    data[['GDP','Consumption']],
    det_order=0,
    k_ar_diff=1
)

print(jres.lr1)

##### Goal: Test whether GDP is stationary or contains a unit root.
